# Tests for safe-div and safe-mod — zero-denominator cases

import prelude as P
import assert as A
import arithmetic as Ar
import result as Res
import typeclass::equality as Eq

open A exposing assert-eq end
open Eq exposing Equality end
open P exposing Result::ok Result::err end

module test::arithmetic::safe-div-mod contains
  define transparent test-safe-div as compute
    perform (P::sequence-unit
      [
        (assert-eq Boolean (Res::is-ok Natural String (Ar::safe-div 10 2)) true)
      , (assert-eq Natural (Res::unwrap-or Natural String 0 (Ar::safe-div 10 2)) 5)
      , (assert-eq Natural (Res::unwrap-or Natural String 0 (Ar::safe-div 0 5)) 0)
      , (assert-eq Boolean (Res::is-err Natural String (Ar::safe-div 10 0)) true)
      , (assert-eq Boolean (Res::is-err Natural String (Ar::safe-div 0 0)) true)
      ])
  end

  define transparent test-safe-mod as compute
    perform (P::sequence-unit
      [
        (assert-eq Boolean (Res::is-ok Natural String (Ar::safe-mod 10 3)) true)
      , (assert-eq Natural (Res::unwrap-or Natural String 0 (Ar::safe-mod 10 3)) 1)
      , (assert-eq Natural (Res::unwrap-or Natural String 0 (Ar::safe-mod 0 5)) 0)
      , (assert-eq Boolean (Res::is-err Natural String (Ar::safe-mod 10 0)) true)
      , (assert-eq Boolean (Res::is-err Natural String (Ar::safe-mod 0 0)) true)
      ])
  end

  define transparent main as compute
    perform (P::sequence-unit
      [
        test-safe-div
      , test-safe-mod
      ])
  end
end
