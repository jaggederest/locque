import prelude as P
# Test rollup for tools modules
# Runs all tests in test/tools/

import test::tools::tokenizer as tokenizer
import test::tools::validator as validator
import test::tools::formatter as formatter
import test::tools::formatter_indent as formatter_indent
import test::tools::count as count
import test::tools::dependencies as dependencies

module test::tools contains
  define transparent main as compute
    perform (P::sequence-unit
      [
        tokenizer::main
      , validator::main
      , formatter::main
      , formatter_indent::main
      , count::main
      , dependencies::main
      ])
  end
end
